@model GoldNote.Models.Subscription.SubscriptionModel

@{
    ViewData["Title"] = "Become a Teacher";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h1>@ViewData["Title"]</h1>
        <p class="lead">Create your classroom name to get started for free.</p>

        <hr />

        <form id="teacherForm" asp-action="BecomeTeacher" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="SelectedPlan" value="Promotional" />

            <h3>Classroom Details</h3>
            <div class="form-group mb-4">
                <label asp-for="ClassroomName">Class Room Name</label>
                <input asp-for="ClassroomName" class="form-control" placeholder="E.g., Mr. Smith's Music Studio" />
                <span asp-validation-for="ClassroomName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" id="registerAsTeacher" class="btn btn-warning btn-lg text-dark fw-bold">Complete Registration</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function () {
            // 1. Setup Token
            var token = $('input[name="__RequestVerificationToken"]').val();
            if (token) {
                $.ajaxSetup({ headers: { 'RequestVerificationToken': token } });
            }

            // 2. Handle the Form Submit
            $('#registerAsTeacher').on('click', function (e) {
                e.preventDefault();

                var $form = $('#teacherForm');

                // Debugging: Check if form was found
                if ($form.length === 0) {
                    console.error("Form not found! Check your HTML ID.");
                    return;
                }

                // Check validation
                if (!$form.valid()) {
                    console.log("Form is invalid");
                    return;
                }

                var $btn = $(this);
                $btn.prop('disabled', true).text('Setting up Classroom...');

                $.ajax({
                    url: '/Subscription/BecomeTeacher',
                    type: 'POST',
                    data: $form.serialize(), // This will automatically include the hidden "Promotional" value
                    success: function (response) {
                        if (response.success) {
                            window.location.href = response.redirectUrl;
                        } else {
                            alert("Error: " + response.message);
                            $btn.prop('disabled', false).text('Complete Registration');
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error("AJAX Error:", error);
                        console.log("Response Text:", xhr.responseText);
                        alert("Something went wrong creating the class.");
                        $btn.prop('disabled', false).text('Complete Registration');
                    }
                });
            });
        });
    </script>
}