@{
    ViewData["Title"] = "Create New Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Gold Note</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background-color: #000; color: #fff; height: 100vh; display: flex; align-items: center; justify-content: center; font-family: 'Segoe UI', sans-serif; }
        .card-gold { background-color: #111; border: 1px solid #4a3700; border-radius: 10px; padding: 40px; width: 100%; max-width: 400px; box-shadow: 0 0 20px rgba(212, 175, 55, 0.2); }
        h2 { color: #FFD700; text-align: center; text-transform: uppercase; margin-bottom: 20px; font-size: 1.5rem; }
        p { color: #ccc; text-align: center; font-size: 0.9rem; margin-bottom: 30px; }
        label { color: #FFD700; margin-bottom: 5px; display: block; }
        .gold-input { background-color: #222; border: 1px solid #444; color: #fff; width: 100%; padding: 10px; border-radius: 5px; margin-bottom: 20px; }
        .gold-input:focus { outline: none; border-color: #FFD700; }
        .btn-gold { width: 100%; padding: 12px; font-weight: bold; background: linear-gradient(90deg, #4a3700 0%, #FFD700 50%, #4a3700 100%); border: none; color: #000; border-radius: 5px; }
        .btn-gold:hover { background: linear-gradient(90deg, #FFD700, #ffe033, #FFD700); }
    </style>
</head>
<body>
    <div class="card-gold">
        <h2>New Password</h2>

        @if (ViewBag.Message != null)
        {
            <div class="alert alert-danger text-center">@ViewBag.Message</div>
        }
        else
        {
            <p>Please enter your new password below.</p>

            <form asp-action="ResetPassword" asp-controller="Account" method="post">
                <input type="hidden" name="token" value="@ViewBag.Token" />

                <label>New Password</label>
                <input type="password" name="newPassword" class="gold-input" required placeholder="Enter new password" />

                <button type="submit" class="btn-gold">Update Password</button>
            </form>
        }
    </div>
</body>
</html>