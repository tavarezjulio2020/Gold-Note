<div class="text-center">
    <h1 class="display-4 text-gold-metallic">@ViewBag.Username</h1>

   <div class="d-flex justify-content-center align-items-center mb-4">
    <h2 class="m-0 me-3 text-white">Class Code: <span class="text-gold">@ViewBag.ClassCode.ClassCode</span></h2>

    <div style="position: relative;">
        <button type="button" class="btn btn-link text-white p-0 ms-2" data-bs-toggle="modal" data-bs-target="#RequestModal" style="text-decoration: none;">
            <i class="fas fa-envelope fa-2x position-relative">
                <span id="request-badge" class="notification-badge hidden"></span>
            </i>
        </button>
    </div>

    <div class="ms-4">
        <button type="button" class="btn btn-gold" data-bs-toggle="modal" data-bs-target="#ToolsModal">
            <i class="fas fa-toolbox"></i> Tools
        </button>
    </div>
   </div>
</div>

@Html.AntiForgeryToken()

<div class="row">
    <div class="col-md-10 offset-md-1">
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle">
                <thead class="text-center">
                    <tr>
                        <th>Student</th>
                        <th class="d-none d-md-table-cell">Instrument</th>
                        <th>Weekly Practice</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="studentTableBody">
                    @* Populated via AJAX *@
                </tbody>
            </table>
        </div>
    </div>
</div>

@* --- MODAL FOR STUDENT STATS --- *@
<div class="modal fade" id="StudentStatsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content bg-black border-secondary">
            <div class="modal-header" style="border-bottom: 1px solid #4a3700;">
                <h5 class="modal-title text-gold-metallic" id="StudentStatsModalLabel">Student Stats</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">

                <div class="row mb-4 bg-dark p-3 rounded border border-secondary mx-1">
                    <div class="col-md-5">
                        <label class="text-gold small fw-bold text-uppercase mb-1">Start Date</label>
                        <input type="date" id="statsStartDate" class="form-control bg-black text-white border-secondary">
                    </div>
                    <div class="col-md-5">
                        <label class="text-gold small fw-bold text-uppercase mb-1">End Date</label>
                        <input type="date" id="statsEndDate" class="form-control bg-black text-white border-secondary">
                    </div>
                    <div class="col-md-2 d-flex align-items-end mt-3 mt-md-0">
                        <button class="btn btn-gold w-100" id="applyStatsFilterBtn">Apply</button>
                    </div>
                </div>

                <div class="mb-4">
                    <h6 class="text-white mb-3"><i class="fas fa-chart-line text-gold me-2"></i>Daily Practice</h6>
                    <div style="height: 250px; width: 100%;">
                        <canvas id="studentPracticeChart"></canvas>
                    </div>
                </div>

                <hr class="border-secondary my-4" style="opacity: 0.3;">

                <div>
                    <h6 class="text-white mb-3"><i class="fas fa-tasks text-gold me-2"></i>Assignments Practiced</h6>
                    <div style="height: 250px; width: 100%;">
                        <canvas id="studentAssignmentChart"></canvas>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>


@* --- MODAL FOR CLASSROOM REQUESTS --- *@
<div class="modal fade" id="RequestModal" tabindex="-1" aria-labelledby="RequestModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header border-secondary">
                <h5 class="modal-title text-gold-metallic" id="RequestModalLabel">Pending Classroom Requests</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="requestsContainer">
                    <div class="text-center my-3">
                        <i class="fas fa-spinner fa-spin fa-2x text-gold"></i>
                        <p class="text-muted mt-2">Loading requests...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* --- MODAL FOR EDITING ASSIGNMENTS --- *@
<div class="modal fade" id="EditAssignmentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="editAssignmentForm">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title text-gold-metallic">Edit Assignment</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="editAssignmentId" name="assignmentId">
                    <div class="mb-3">
                        <label for="editTitle" class="form-label text-gold">Title</label>
                        <input type="text" class="form-control" id="editTitle" name="title" required>
                    </div>
                    <div class="mb-3">
                        <label for="editDescription" class="form-label text-gold">Description</label>
                        <textarea class="form-control" id="editDescription" name="description" rows="3" required></textarea>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-gold">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* --- MODAL FOR ADDING ASSIGNMENTS --- *@
<div class="modal fade" id="AddAssignmentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="addAssignmentForm">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title text-gold-metallic">Add New Assignment</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="addAssignmentLearnId" name="learnId">
                    <div class="mb-3">
                        <label for="addTitle" class="form-label text-gold">Title</label>
                        <input type="text" class="form-control" id="addTitle" name="title" required>
                    </div>
                    <div class="mb-3">
                        <label for="addDescription" class="form-label text-gold">Description</label>
                        <textarea class="form-control" id="addDescription" name="description" rows="3" required></textarea>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-gold">Add Assignment</button>
                </div>
            </form>
        </div>
    </div>
</div>


@* --- MODAL FOR CLASS TOOLS (TAGS & BULK ASSIGNMENTS) --- *@
<div class="modal fade" id="ToolsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content bg-black border-secondary">
            <div class="modal-header" style="border-bottom: 1px solid #4a3700;">
                <h5 class="modal-title text-gold-metallic"><i class="fas fa-tools text-gold me-2"></i> Class Tools</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">

                <div class="mb-4 bg-dark p-3 rounded border border-secondary mx-1">
                    <h6 class="text-gold mb-2">1. Create a Tag</h6>
                    <div class="input-group">
                        <input type="text" id="newTagName" class="form-control bg-black text-white border-secondary" placeholder="Type a tag name (like 'Beginners' or 'Piano')">
                        <button class="btn btn-outline-light" id="createTagBtn">Create Tag</button>
                    </div>
                </div>

                <div class="mb-4 bg-dark p-3 rounded border border-secondary mx-1">
                    <h6 class="text-gold mb-2">2. Assign Tag to Student</h6>
                    <div class="row">
                        <div class="col-md-5">
                            <label class="text-white small mb-1">Select students (Tap to check)</label>
                            <div id="studentCheckboxContainer" class="bg-black border border-secondary rounded p-2" style="max-height: 150px; overflow-y: auto;">
                            </div>
                        </div>
                        <div class="col-md-5 mt-2 mt-md-0">
                            <select id="tagListSelect" class="form-select bg-black text-white border-secondary">
                                <option value="">Select Tag...</option>
                                </select>
                        </div>
                        <div class="col-md-2 mt-2 mt-md-0">
                            <button class="btn btn-outline-light w-100" id="assignTagToStudentBtn">Assign</button>
                        </div>
                    </div>
                </div>

                <div class="bg-dark p-3 rounded border border-secondary mx-1 mb-2">
                    <h6 class="text-gold mb-2">3. Send General Assignment</h6>
                    <div class="mb-3">
                        <label class="text-white small mb-1">Who gets this assignment?</label>
                        <select id="bulkAssignTarget" class="form-select bg-black text-white border-secondary">
                            <option value="ALL">All My Students</option>
                            </select>
                    </div>
                    <div class="mb-3">
                        <input type="text" id="bulkAssignTitle" class="form-control bg-black text-white border-secondary" placeholder="Assignment Title">
                    </div>
                    <div class="mb-3">
                        <textarea id="bulkAssignDescription" class="form-control bg-black text-white border-secondary" placeholder="Assignment Description" rows="2"></textarea>
                    </div>
                    <button class="btn btn-gold w-100" id="sendBulkAssignBtn">Send Assignment</button>
                </div>

            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        // --- GLOBAL VARIABLES ---
        let practiceLineChart = null;
        let assignmentBarChart = null;

        $(document).ready(function () {
            // 1. Setup Token
            var token = $('input[name="__RequestVerificationToken"]').val();
            $.ajaxSetup({ headers: { 'RequestVerificationToken': token } });

            // 2. Initial Data Loads
            getStudents();
            checkInitialRequests();

            // --- EVENT HANDLERS ---
            $('#RequestModal').on('show.bs.modal', function () { loadRequests(); });
            $(document).on('click', '.accept-btn', function () { processRequest($(this).data('request-id'), $(this).data('student-learn-id'), 'Acceptrequest'); });
            $(document).on('click', '.reject-btn', function () { processRequest($(this).data('request-id'), 0, 'Rejectrequest'); });

            $(document).on('click', '.student-stats-link', function (e) {
                e.preventDefault();
                const learnId = $(this).data('learn-id');
                const studentName = $(this).data('name');

                $('#StudentStatsModalLabel').text(`${studentName}'s Practice Stats`);
                
                // Set default dates (Last 7 days to Today)
                const today = new Date();
                const lastWeek = new Date();
                lastWeek.setDate(today.getDate() - 7);
                
                $('#statsStartDate').val(lastWeek.toISOString().split('T')[0]);
                $('#statsEndDate').val(today.toISOString().split('T')[0]);

                // Store the learnId on the Apply button so it knows who to fetch data for
                $('#applyStatsFilterBtn').data('learn-id', learnId);

                $('#StudentStatsModal').modal('show');
                loadStudentStats(learnId);
            });

            // Assignment Modal Handlers
            $(document).on('click', '.edit-assignment-btn', function () {
                $('#editAssignmentId').val($(this).data('assignment-id'));
                $('#editTitle').val($(this).data('title'));
                $('#editDescription').val($(this).data('description'));
                new bootstrap.Modal(document.getElementById('EditAssignmentModal')).show();
            });
            $('#editAssignmentForm').on('submit', function (e) {
                e.preventDefault();
                editAssignment($('#editAssignmentId').val(), $('#editTitle').val(), $('#editDescription').val());
            });
            $(document).on('click', '.delete-assignment-btn', function () { deleteAssignment($(this).data('assignment-id')); });
            $(document).on('click', '.add-assignment-modal-btn', function () {
                $('#addAssignmentLearnId').val($(this).data('learn-id'));
                $('#addTitle').val('');
                $('#addDescription').val('');
                new bootstrap.Modal(document.getElementById('AddAssignmentModal')).show();
            });
            $('#addAssignmentForm').on('submit', function (e) {
                e.preventDefault();
                addAssignment($('#addAssignmentLearnId').val(), $('#addTitle').val(), $('#addDescription').val());
            });
            $(document).on('click', '.drop-student-btn', function () {
                var learnId = $(this).data('learn-id');
                if (confirm('Are you sure you want to remove this student from your class?')) { dropStudent(learnId); }
            });

             // Apply Filter Button Click Handler
            $('#applyStatsFilterBtn').on('click', function() {
                const learnId = $(this).data('learn-id');
                loadStudentStats(learnId);
            });
            //loadRequests tags
            $('#ToolsModal').on('show.bs.modal', function () {
               loadTags();
            });

            $('#createTagBtn').on('click', function() {
               var tagName = $('#newTagName').val();
               if (!tagName) { alert('Please type a tag name first.'); return; }

               $.post('/Teacher/CreateTag', { name: tagName }, function() {
                   $('#newTagName').val(''); // clear input
                   loadTags(); // reload the dropdowns
                   alert('Tag created!');
               }).fail(function(xhr) { alert("Error: " + xhr.responseText); });
            });

            $('#assignTagToStudentBtn').on('click', function () {
                // Create an empty array, then find every checked box and push its value into the array
                var learnIds = [];
                $('.student-tag-checkbox:checked').each(function () {
                    learnIds.push($(this).val());
                });

                var tagId = $('#tagListSelect').val();

                // Validate
                if (learnIds.length === 0 || !tagId) {
                    alert('Please check at least one student and select a tag.');
                    return;
                }

                // Send to C#
                $.ajax({
                    url: '/Teacher/AssignTag',
                    type: 'POST',
                    traditional: true, // This is still required to send arrays properly to C#
                    data: { studentLearnIds: learnIds, tagId: tagId },
                    success: function () {
                        alert('Tags assigned to selected students!');

                        // Uncheck all the boxes to reset the form
                        $('.student-tag-checkbox').prop('checked', false);
                        $('#tagListSelect').val('');
                    },
                    error: function (xhr) {
                        alert("Error: " + xhr.responseText);
                    }
                });
            });

            $('#sendBulkAssignBtn').on('click', function() {
                var target = $('#bulkAssignTarget').val(); // "ALL" or a tagId
                var title = $('#bulkAssignTitle').val();
                var desc = $('#bulkAssignDescription').val();
            
                if (!title || !desc) { alert('Please fill out the title and description.'); return; }
            
                $.post('/Teacher/BulkAddAssignment', { targetId: target, title: title, description: desc }, function() {
                    alert('Assignments sent out!');
                    $('#bulkAssignTitle').val('');
                    $('#bulkAssignDescription').val('');
                    $('#ToolsModal').modal('hide');
                    getStudents(); // refresh the table
                }).fail(function(xhr) { alert("Error: " + xhr.responseText); });
            });
        });


        // UPDATED: Fetches data using the dates in the input fields
        function loadStudentStats(learnId) {
            const startDate = $('#statsStartDate').val();
            const endDate = $('#statsEndDate').val();

            $.ajax({
                // Changed endpoint name to be more accurate
                url: '/Teacher/GetStudentStats', 
                data: { learnId: learnId, start: startDate, end: endDate },
                type: 'GET',
                success: function(response) {
                    if(response.success) {
                        renderPracticeLineChart(response.dailyData);
                        renderAssignmentBarChart(response.assignmentData);
                    }
                },
                error: function() {
                    console.error("Failed to load student stats");
                }
            });
        }

        // ==========================================
        //            CHART FUNCTIONS
        // ==========================================

         function renderPracticeLineChart(dailyData) {
            const ctx = document.getElementById('studentPracticeChart').getContext('2d');
            if (practiceLineChart) practiceLineChart.destroy();

            // 1. Map existing server data into a dictionary for quick lookup
            const practiceMap = {};
            if (dailyData && dailyData.length > 0) {
                dailyData.forEach(d => {
                    // Grab just the YYYY-MM-DD part to ignore time/timezone discrepancies
                    const dateStr = d.date.split('T')[0];
                    practiceMap[dateStr] = d.minutes;
                });
            }

            // 2. Read the current date range from the inputs on your modal
            const startDateStr = $('#statsStartDate').val();
            const endDateStr = $('#statsEndDate').val();

            // 3. Loop from start to end date, filling in missing days with 0
            // We append 'T00:00:00Z' to force UTC so the browser doesn't accidentally shift dates backwards a day
            const start = new Date(startDateStr + 'T00:00:00Z');
            const end = new Date(endDateStr + 'T00:00:00Z');
            
            const chartData = [];
            let current = new Date(start);

            while (current <= end) {
                const dateStr = current.toISOString().split('T')[0];
                
                chartData.push({
                    x: dateStr,
                    y: practiceMap[dateStr] || 0 // Use actual minutes, or default to 0 if missing
                });
                
                // Move forward by exactly 1 day
                current.setUTCDate(current.getUTCDate() + 1);
            }

            practiceLineChart = new Chart(ctx, {
                type: 'line',
                data: {
                    datasets: [{
                        label: 'Minutes Practiced',
                        data: chartData, // Use our newly padded array
                        borderColor: '#FFD700',
                        backgroundColor: 'rgba(255, 215, 0, 0.2)',
                        borderWidth: 2,
                        pointRadius: 4,
                        fill: true,
                        tension: 0.3 // You can change this to 0 if you want jagged lines instead of curves
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: {
                            type: 'time',
                            time: { unit: 'day', tooltipFormat: 'MMM d, yyyy' },
                            grid: { color: '#333' },
                            ticks: { color: '#ccc' }
                        },
                        y: {
                            beginAtZero: true,
                            grid: { color: '#333' },
                            ticks: { color: '#ccc' }
                        }
                    },
                    plugins: { legend: { display: false } }
                }
            });
        }

        function renderAssignmentBarChart(assignmentData) {
            const ctx = document.getElementById('studentAssignmentChart').getContext('2d');
            if (assignmentBarChart) assignmentBarChart.destroy();

            const labels = assignmentData.map(d => d.title);
            const dataPoints = assignmentData.map(d => d.count);

            assignmentBarChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Times Practiced',
                        data: dataPoints,
                        backgroundColor: '#d4af37',
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: {
                            grid: { display: false },
                            ticks: { color: '#ccc' }
                        },
                        y: {
                            beginAtZero: true,
                            grid: { color: '#333' },
                            ticks: { color: '#ccc', stepSize: 1 }
                        }
                    },
                    plugins: { legend: { display: false } }
                }
            });
        }

        // ==========================================
        //           EXISTING FUNCTIONS
        // ==========================================

        function getStudents() {
            $.ajax({
                url: '/Teacher/GetMyStudents',
                type: 'GET',
                dataType: 'json',
                success: function (data) {
                    var html = "";

                    // 1. Clear out the new checkbox container
                    var $checkboxContainer = $('#studentCheckboxContainer');
                    $checkboxContainer.empty();

                    if (data.length === 0) {
                        $checkboxContainer.append('<p class="text-muted small m-0">No students yet.</p>');
                    }

                    $.each(data, function (i, student) {
                        // 2. Build a touch-friendly checkbox for each student
                        var checkboxHtml = `
                            <div class="form-check mb-1">
                                <input class="form-check-input student-tag-checkbox" type="checkbox" value="${student.learnId}" id="chk_student_${student.learnId}">
                                <label class="form-check-label text-white" style="cursor: pointer; width: 100%;" for="chk_student_${student.learnId}">
                                    ${student.studentName}
                                </label>
                            </div>`;
                        $checkboxContainer.append(checkboxHtml);

                        // 3. Build the main student table (Your existing code)
                        html += `<tr data-learn-id="${student.learnId}">
                                    <td class="text-center">
                                        <a href="#" class="student-stats-link text-gold" style="text-decoration: none; font-weight: bold; border-bottom: 1px dashed #FFD700;" data-learn-id="${student.learnId}" data-name="${student.studentName}">
                                            ${student.studentName}
                                        </a>
                                    </td>
                                            <td class="text-center text-white d-none d-md-table-cell">${student.instrumentName}</td>
                                    <td class="text-center text-white">${timeDisplay(student.secondsPracticed)}</td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <button class="btn btn-sm btn-gold toggle-assignments-btn" data-learn-id="${student.learnId}" title="Assignments">
                                                <i class="fas fa-list"></i> <span class="d-none d-md-inline ms-1">Assignments</span>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger drop-student-btn" data-learn-id="${student.learnId}" title="Drop Student">
                                                <i class="fas fa-user-minus"></i>
                                            </button>
                                        </div>
                                    </td>
                                 </tr>
                                 <tr class="assignment-row assignment-row-${student.learnId}" style="display:none;">
                                    <td colspan="4"><div id="assignments-container-${student.learnId}" class="p-3 bg-dark">Loading...</div></td>
                                 </tr>`;
                    });

                    // Put the table HTML onto the page
                    $('#studentTableBody').html(html);

                    // Re-attach the toggle events for the assignments
                    $('.toggle-assignments-btn').on('click', function () {
                        var learnId = $(this).data('learn-id');
                        var $row = $(`.assignment-row-${learnId}`);
                        var $span = $(this).find('span');
                        var $icon = $(this).find('i');

                        if ($row.is(':hidden')) {
                            getAssignments(learnId);
                            $span.text('Hide');
                            $icon.removeClass('fa-list').addClass('fa-chevron-up');
                        } else {
                            $span.text('Assignments');
                            $icon.removeClass('fa-chevron-up').addClass('fa-list');
                        }
                        $row.toggle();
                    });
                }
            });
        }

        function getAssignments(learnId) {
            var $container = $('#assignments-container-' + learnId);
            $container.html('<div class="text-center text-white"><i class="fas fa-spinner fa-spin"></i> Loading...</div>');
            $.ajax({
                url: '/Teacher/GetAssignments',
                data: { studentLearnId: learnId },
                type: 'GET',
                success: function (data) { $container.html(renderAssignmentsTable(data, learnId)); },
                error: function (xhr) { $container.html(`<p class="text-danger text-center">Error loading assignments.</p>`); }
            });
        }

        function renderAssignmentsTable(assignments, learnId) {
            let html = `
                        <div class="card border-secondary">
                            <div class="card-header position-relative d-flex align-items-center" style="background-color: #111; border-bottom: 1px solid #444; height: 50px;">
                                <span class="h5 m-0 position-absolute top-50 start-50 translate-middle text-gold-metallic">Assignments</span>
                                <div class="w-100 d-flex justify-content-end">
                                    <button class="btn btn-gold btn-sm add-assignment-modal-btn" data-learn-id="${learnId}"><i class="fas fa-plus"></i> Add New</button>
                                </div>
                            </div>
                            <table class="table table-dark table-hover table-sm mb-0 align-middle">
                                <thead>
                                    <tr style="border-bottom: 2px solid #444; background-color: #000 !important;">
                                        <th class="text-center" style="width: 30%; background-color: #000;">Title</th>
                                        <th class="text-center" style="width: 50%; background-color: #000;">Description</th>
                                        <th class="text-center" style="width: 20%; background-color: #000;">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>`;
            if (assignments && assignments.length > 0) {
                $.each(assignments, function (i, item) {
                    const safeTitle = $('<div>').text(item.title).html();
                    const safeDesc = $('<div>').text(item.description).html();
                    html += `<tr>
                                        <td class="text-white text-center">${safeTitle}</td>
                                        <td class="text-white text-start text-wrap" style="max-width: 0;">${safeDesc}</td>
                                        <td class="text-center">
                                            <div class="d-flex justify-content-center gap-2">
                                                <button class="btn btn-sm btn-outline-primary edit-assignment-btn" data-assignment-id="${item.assignmentId}" data-title="${safeTitle}" data-description="${safeDesc}"><i class="fas fa-edit"></i></button>
                                                <button class="btn btn-sm btn-outline-danger delete-assignment-btn" data-assignment-id="${item.assignmentId}"><i class="fas fa-trash"></i></button>
                                            </div>
                                        </td>
                                    </tr>`;
                });
            } else { html += `<tr><td colspan="3" class="text-center text-muted py-3">No assignments yet.</td></tr>`; }
            html += `</tbody></table></div>`;
            return html;
        }

        function addAssignment(learnId, title, description) { $.post('/Teacher/AddAssignment', { learnId, title, description }, function () { $('#AddAssignmentModal').modal('hide'); getAssignments(learnId); }).fail(function (xhr) { alert("Error: " + xhr.responseText); }); }
        function editAssignment(id, title, description) { $.ajax({ url: '/Teacher/EditAssignment', type: 'PUT', data: { assignmentId: id, title, description }, success: function () { $('#EditAssignmentModal').modal('hide'); getStudents(); } }); }
        function deleteAssignment(id) { $.ajax({ url: '/Teacher/DeleteAssignment', type: 'DELETE', data: { assignmentId: id }, success: function () { getStudents(); } }); }
        function dropStudent(learnId) { $.ajax({ url: '/Teacher/DropStudent', type: 'DELETE', data: { learnId: learnId }, success: function () { getStudents(); }, error: function (xhr) { alert("Error: " + xhr.responseText); } }); }

        function checkInitialRequests() { $.get('/Teacher/GetJoinRequest', function (data) { $('#request-badge').toggleClass('hidden', !data || data.length === 0); }); }
        function loadRequests() {
            var $container = $('#requestsContainer');
            $container.html('<div class="text-center"><i class="fas fa-spinner fa-spin text-gold"></i> Loading...</div>');
            $.get('/Teacher/GetJoinRequest', function (data) {
                if (!data || data.length === 0) { $container.html('<p class="text-center text-muted">No pending requests.</p>'); return; }
                var html = '<table class="table table-dark table-hover align-middle"><thead><tr><th class="text-center">Student</th><th class="text-center">Instrument</th><th class="text-center">Actions</th></tr></thead><tbody>';
                $.each(data, function (i, req) { html += `<tr><td>${req.studentName}</td><td>${req.instrumentName}</td><td><button class="btn btn-outline-success btn-sm accept-btn me-2" data-request-id="${req.requestId}" data-student-learn-id="${req.learnId}">Accept</button><button class="btn btn-outline-danger btn-sm reject-btn" data-request-id="${req.requestId}">Reject</button></td></tr>`; });
                html += '</tbody></table>'; $container.html(html);
            });
        }
        function processRequest(reqId, learnId, action) { let verb = (action === 'Rejectrequest') ? 'DELETE' : 'POST'; $.ajax({ url: '/Teacher/' + action, type: verb, data: { requestId: reqId, studentLearnId: learnId }, success: function () { loadRequests(); getStudents(); checkInitialRequests(); }, error: function () { alert("Action failed."); } }); }
        function timeDisplay(totalSeconds) { if (!totalSeconds || totalSeconds < 0) return "0s"; var h = Math.floor(totalSeconds / 3600); var m = Math.floor((totalSeconds % 3600) / 60); var s = Math.floor(totalSeconds % 60); var parts = []; if (h > 0) parts.push(h + 'h'); if (m > 0) parts.push(m + 'm'); if (s > 0 || parts.length === 0) parts.push(s + 's'); return parts.join(' '); }
   
      function loadTags() {
         // You will need a C# endpoint that returns the teacher's tags
         $.get('/Teacher/GetTags', function(tags) {
             $('#tagListSelect').empty().append('<option value="">Select Tag...</option>');
             $('#bulkAssignTarget').empty().append('<option value="ALL">All My Students</option>');

             if (tags && tags.length > 0) {
                 $.each(tags, function(i, tag) {
                     // Add to the assign dropdown
                     $('#tagListSelect').append(`<option value="${tag.tagId}">${tag.tagName}</option>`);
                     // Add to the bulk assignment dropdown
                     $('#bulkAssignTarget').append(`<option value="${tag.tagId}">Tag Group: ${tag.tagName}</option>`);
                 });
             }
         });
      }
    </script>

    <style>
        .table thead th {
            vertical-align: middle;
        }

        #studentTableBody > tr:not(.assignment-row) > td {
            color: white !important;
        }

        .assignment-row td {
            background-color: #000;
            padding: 10px 20px;
        }

        .hidden {
            display: none;
        }
    </style>
}